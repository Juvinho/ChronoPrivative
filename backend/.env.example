# Banco de Dados PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/chronoprivative_db

# Autenticação
JWT_SECRET=seu_jwt_secret_super_seguro_aqui_mude_isso_em_producao
ADMIN_PASSWORD=suaSenhaEspecificaAqui

# Servidor
PORT=4000  # Fallback: 3002 (se variável não definida)
NODE_ENV=development

# CORS — domínio do frontend
CORS_ORIGIN=http://localhost:3000
